FROM golang:1.24-alpine AS builder
WORKDIR /src
COPY target/go.mod target/go.sum ./
RUN go mod download
COPY target/*.go ./
RUN go mod tidy && CGO_ENABLED=0 go build -o /target-server .

FROM alpine:3.21
RUN apk add --no-cache curl openssl && \
    openssl req -x509 -newkey rsa:2048 -keyout /server.key -out /server.crt \
    -days 3650 -nodes -subj "/CN=localhost" -addext "subjectAltName=DNS:localhost,DNS:target,IP:127.0.0.1" && \
    apk del openssl
COPY --from=builder /target-server /target-server
EXPOSE 80 443
ENTRYPOINT ["/target-server"]
